mainlib <- c("tidyverse", "dplyr", "sf", "ggplot2")
lapply(mainlib, library, character.only = TRUE)
thaiRoad |> ggplot(aes(x = SpeedLimit, color = RoadClass)) + geom_histogram(stat = "bin") + facet_wrap(~RoadClass)
indiaRoad |> ggplot(aes(x = SpeedLimit, color = RoadClass)) + geom_histogram(stat = "bin") + facet_wrap(~RoadClass)
thaiRoad |> ggplot(aes(x = SpeedLimit, fill = RoadClass)) + geom_histogram(stat = "bin") + facet_wrap(~RoadClass)
indiaRoad |> ggplot(aes(x = SpeedLimit, fill = RoadClass)) + geom_histogram(stat = "bin") + facet_wrap(~RoadClass)
thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, fill = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + facet_wrap(~SpeedLimit) + theme_minimal()
thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + facet_wrap(~SpeedLimit) + theme_minimal()
thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + facet_wrap(~SpeedLimit) + theme_minimal() + theme(legend.position = "bottom")
thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + facet_wrap(~SpeedLimit) + theme_minimal() + theme(legend.position = "bottom")
thaiVar2 <- left_join(thaiVar, thaiRisk, by = "OBJECTID")
indiaVar2 <- left_join(indiaVar, thaiRisk, by = "OBJECTID")
head(thaiVar2)
head(indiaVar2)
thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + scale_size_continuous(range = c(2, 12)) + facet_wrap(~SpeedLimit) + theme_minimal() + theme(legend.position = "bottom")
thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + geom_vline(aes(xintercept = SpeedLimit), linetype = "dashed", color = "grey40") + scale_size_continuous(range = c(2, 12)) + facet_wrap(~SpeedLimit) + theme_minimal() + theme(legend.position = "bottom")
thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + geom_hline(aes(xintercept = SpeedLimit), linetype = "dashed", color = "grey40") + scale_size_continuous(range = c(2, 12)) + facet_wrap(~SpeedLimit) + theme_minimal() + theme(legend.position = "bottom")
thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + geom_hline(aes(yintercept = SpeedLimit), linetype = "dashed", color = "grey40") + scale_size_continuous(range = c(2, 12)) + facet_wrap(~SpeedLimit) + theme_minimal() + theme(legend.position = "bottom")
thaiVar2 |> ggplot(aes(x = RoadClass, y = image_risk_score, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + geom_hline(aes(yintercept = SpeedLimit), linetype = "dashed", color = "grey40") + scale_size_continuous(range = c(2, 12)) + facet_wrap(~SpeedLimit) + theme_minimal() + theme(legend.position = "bottom")
thaiVar2 |>
ggplot(aes(x = RoadClass, y = image_risk_score, color = RoadClass, size = PercentOverLimit)) +
geom_point(alpha = 0.5) +
#geom_hline(aes(yintercept = SpeedLimit), linetype = "dashed", color = "grey40") +
scale_size_continuous(range = c(2, 12)) +
facet_wrap(~SpeedLimit) +
theme_minimal() +
theme(legend.position = "bottom")
thaiVar2 |>
ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = image_risk_score)) +
geom_point(alpha = 0.5) +
geom_hline(aes(yintercept = SpeedLimit), linetype = "dashed", color = "grey40") +
scale_size_continuous(range = c(2, 12)) +
facet_wrap(~SpeedLimit) +
