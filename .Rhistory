colnames(thaiRisk)
thaiVarinclude <- thaiVar |>
select(
#identity
"OBJECTID",
#positive
"vlm_population_density_score",
"yolo_total_vehicles",
"vlm_footpath_score",
"vlm_lane_marking_quality",
"yolo_total_pedestrians",
"vlm_road_condition_score",
"yolo_total_bicycles",
# negatives
"vlm_lane_count",
# "vlm_curvature_visible",
"vlm_intersection_visible",
"yolo_total_motorcycles"
# "vlm_overall_walkability"
# "vlm_building_density_score"
)
thaiAll <- thaiSafety |>
left_join(thaiVarinclude, by = "OBJECTID") |>
left_join(thaiRisk, by = "OBJECTID")
thaiAll |>
ggplot(aes(x = SpeedSafetyScore, y = image_risk_score, size = vlm_population_density_score, fill = RoadClass)) +
geom_point(alpha = 0.4) +
theme_minimal()
thaiAll |>
ggplot(aes(x = SpeedSafetyScore, y = image_risk_score, size = vlm_population_density_score, fill = factor(RoadClass))) +
geom_point(alpha = 0.4) +
theme_minimal()
thaiAll |>
ggplot(aes(x = SpeedSafetyScore, y = image_risk_score, size = vlm_population_density_score, color = RoadClass)) +
geom_point(alpha = 0.4) +
theme_minimal()
thaiAll |>
ggplot(aes(x = SpeedSafetyScore, y = image_risk_score, size = vlm_population_density_score, color = RoadClass)) +
geom_point(alpha = 0.4) +
facet_wrap(~RoadClass) +
theme_minimal()
thaiAll |>
ggplot(aes(x = SpeedSafetyScore, y = image_risk_score, size = vlm_footpath_score, color = RoadClass)) +
geom_point(alpha = 0.4) +
facet_wrap(~RoadClass) +
theme_minimal()
View(thaiAll |> filter(vlm_footpath_score > 0))
View(thaiAll |> filter(vlm_footpath_score > 0))
View(thaiAll |> filter(vlm_footpath_score > 0 & PriorityTier == "Low"))
View(thaiAll |> filter(vlm_footpath_score > 0 & PriorityTier == "Low" & RoadClass == "motorway"))
View(thaiAll |> filter(vlm_footpath_score > 0 & RoadClass == "motorway"))
View(thaiAll |> filter(vlm_footpath_score > 8 & RoadClass == "secondary"))
View(thaiAll |> filter(vlm_footpath_score > 6 & RoadClass == "secondary"))
summary(thaiAll)
