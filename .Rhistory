thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + facet_wrap(~SpeedLimit) + theme_minimal()
thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + facet_wrap(~SpeedLimit) + theme_minimal() + theme(legend.position = "bottom")
