thaiRoad |> ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = PercentOverLimit)) + geom_point(alpha = 0.5) + geom_hline(aes(yintercept = SpeedLimit), linetype = "dashed", color = "grey40") + scale_size_continuous(range = c(2, 12)) + facet_wrap(~SpeedLimit) + theme_minimal() + theme(legend.position = "bottom")
thaiVar2 |>
filter(SpeedLimit > 0) |>
ggplot(aes(x = RoadClass, y = F85thPercentileSpeed, color = RoadClass, size = image_risk_score)) +
geom_point(alpha = 0.5) +
geom_hline(aes(yintercept = SpeedLimit), linetype = "dashed", color = "grey40") +
scale_size_continuous(range = c(2, 12)) +
facet_wrap(~SpeedLimit) +
theme_minimal() +
theme(legend.position = "bottom")
