thaiAll <- thaiAll |>
mutate(
priority_improvement = case_when(
vlm_intersection_visible == 1 & vlm_pedestrian_crossing_visible == 0 ~ "Add pedestrian crossing and adjust the traffic light to prioritize pedestrians & cyclists safety",
vlm_intersection_visible == 0 & vlm_pedestrian_crossing_visible == 0 & vlm_population_density_score >= 5 & RoadClass %in% c("motorway", "trunk") ~ "Provide a bridge for pedestrians and cyclists",
vlm_intersection_visible == 0 & vlm_pedestrian_crossing_visible == 0 & vlm_population_density_score >= 5 ~ "Provide a traffic calming and safety crossing for pedestrians and cyclists",
RoadClass != "motorway" & vlm_footpath_score == 0 ~ "Provide footpath",
vlm_footpath_score > 0 & vlm_footpath_obstruction == 1 ~ "Clear footpaths",
yolo_total_bicycles > 0 & vlm_bike_lane_present == 0 ~ "Provide separated bike lane",
vlm_lane_marking_quality == 0 ~ "Improve lane marking",
PriorityTier %in% c("Critical", "High") & RoadClass %in% c("motorway", "trunk") ~ "Add speed camera/speed limit enforcement",
PriorityTier %in% c("Critical", "High") & RoadClass %in% c("primary", "secondary") &  ~ "Add traffic calming and speed camera/speed limit enforcement",
TRUE ~ "No priority intervention needed"
)
)
thaiAll <- thaiAll |>
mutate(
priority_improvement = case_when(
vlm_intersection_visible == 1 & vlm_pedestrian_crossing_visible == 0 ~ "Add pedestrian crossing and adjust the traffic light to prioritize pedestrians & cyclists safety",
vlm_intersection_visible == 0 & vlm_pedestrian_crossing_visible == 0 & vlm_population_density_score >= 5 & RoadClass %in% c("motorway", "trunk") ~ "Provide a bridge for pedestrians and cyclists",
vlm_intersection_visible == 0 & vlm_pedestrian_crossing_visible == 0 & vlm_population_density_score >= 5 ~ "Provide a traffic calming and safety crossing for pedestrians and cyclists",
RoadClass != "motorway" & vlm_footpath_score == 0 ~ "Provide footpath",
vlm_footpath_score > 0 & vlm_footpath_obstruction == 1 ~ "Clear footpaths",
yolo_total_bicycles > 0 & vlm_bike_lane_present == 0 ~ "Provide separated bike lane",
vlm_lane_marking_quality == 0 ~ "Improve lane marking",
PriorityTier %in% c("Critical", "High") & RoadClass %in% c("motorway", "trunk") ~ "Add speed camera/speed limit enforcement",
PriorityTier %in% c("Critical", "High") & RoadClass %in% c("primary", "secondary") ~ "Add traffic calming and speed camera/speed limit enforcement",
TRUE ~ "No priority intervention needed"
)
)
summary(thaiAll$priority_improvement)
